{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Cucumber Tests",
      "type": "node",
      "request": "launch",
      "runtimeArgs": [
        "--inspect-brk",
        "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber-js"
      ],
      "args": [
        "--require-module",
        "ts-node/register",
        "--require",
        "tests/bdd/**/*.ts"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}